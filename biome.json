{
  "$schema": "https://biomejs.dev/schemas/2.2.5/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noBannedTypes": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!.yarn",
      "!.git",
      "!.vscode",
      "!.pnp.cjs",
      "!.pnp.loader.mjs",
      "!**/.react-router",
      "!**/.react-router/types",
      "!**/node_modules",
      "!**/dist",
      "!**/coverage",
      "!**/__generated__",
      "!**/.ultra.cache.json",
      "!**/package.json"
    ]
  }
}
